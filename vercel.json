{
  "functions": {
    "api/*.py": {
      "maxDuration": 60
    },
    "api/**/*.py": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/autopilot/run",
      "schedule": "*/10 19-21 * * 1-5"
    },
    {
      "path": "/api/autopilot/close",
      "schedule": "*/5 19-21 * * 1-5"
    }
  ]
}